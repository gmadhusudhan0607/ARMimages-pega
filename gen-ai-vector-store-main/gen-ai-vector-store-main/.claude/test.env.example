# VS test configuration
# Copy this file to test.env and fill in your values:
#   cp .claude/test.env.example .claude/test.env
#
# Used by: /perf-test, /diagnostics, /e2e-test
# This file is gitignored - your values stay local.

# SAX secret IDs for token generation (sax issue --secret-id ...)
# Service token - for query, upsert, collection operations
SAX_SECRET_ID=
# Ops token - for isolation create/delete (different secret than service)
SAX_OPS_SECRET_ID=

# Default namespace (optional - override per command, default: genai-vector-store)
# VS_NAMESPACE=

# Report output directory (default: tmp/reports)
# VS_REPORT_DIR=tmp/reports
