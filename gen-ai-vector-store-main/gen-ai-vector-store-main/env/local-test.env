############## Common ##################
CLOUD_PROVIDER=aws
ACCOUNT=
REGION=us-east-1

SERVICE_PORT=
SERVICE_HEALTHCHECK_PORT=

OPS_PORT=
OPS_HEALTHCHECK_PORT=

BKG_HEALTHCHECK_PORT=

ISOLATION_AUTO_CREATION=false
ISOLATION_AUTO_CREATION_MAX_STORAGE_SIZE=1GB

MAX_CONNS=20
ENABLE_RUNTIME_HEADER_CONFIG=true

############## GEN IA MODEL ############
GENAI_GATEWAY_SERVICE_URL=https://dev-pcld-openaiaccount-cg0-eastus2-itigj.openai.azure.com/openai/deployments/text-embedding-ada-002-2/embeddings?api-version=2023-05-15
# Define GENAI_API_KEY in .env file instead here (on project level) for local testing
GEN_AI_API_KEY=

GENAI_SMART_CHUNKING_SERVICE_URL=http://localhost:9998
#GENAI_GATEWAY_SERVICE_URL=http://localhost:9999

############## SAX Server ##############
SAX_DISABLED=true
SAX_JWKS_ENDPOINT=
SAX_ISSUER=
SAX_AUDIENCE=

############## SAX Client ##############
SAX_CLIENT_DISABLED=true
SAX_CLIENT_ID=
SAX_CLIENT_SCOPES=
SAX_CLIENT_SECRET=
SAX_CLIENT_TOKEN_ENDPOINT=
ISOLATION_ID_VERIFICATION_DISABLED=true
# Define token for dev purpose.
# Define SAX_CLIENT_DEV_TOKEN in .env file instead here (on project level) for local testing.
# If defined, It will be used as Client Token to call GENAI_GATEWAY_SERVICE_URL and GENAI_SMART_CHUNKING_SERVICE_URL
#SAX_CLIENT_DEV_TOKEN=
#RANDOM_EMBEDDER_ENABLED=true
#RANDOM_EMBEDDER_DELAY=1

############## DB #######################
# If DB_LOCAL=true credentials are taken from DB_USR and DB_PWD, otherwise from DB_SECRET
DB_LOCAL=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vectordb
DB_USR=testuser
DB_PWD=testpwd
DB_SECRET=
DB_INSTANCE=
DB_WITH_PRIVATE_IP=
DB_USE_LEGACY_ATTRIBUTE_IDS=
DB_SCHEMA_FORCED_MIN_REQUIRED_VERSION=

PGVECTOR_DISTANCE_PRECISION=4

#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
#OTEL_TRACES_SAMPLER=parentbased_traceidratio
#OTEL_TRACES_SAMPLER_ARG=1
#OTEL_RESOURCE_ATTRIBUTES=service.name=genai-vector-store

QUERY_EMBEDDING_TIMEOUT_MS=5000
QUERY_EMBEDDING_MAX_RETRIES=1
