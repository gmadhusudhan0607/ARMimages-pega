{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranches": [
    "main"
  ],
  "bbUseDefaultReviewers": true,
  "prConcurrentLimit": 10,
  "ignoreDeps": [
    "gradle",
    "gradle-wrapper"
  ],
  "schedule": [
    "at any time"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "maven", "artifactory"
      ],
      "registryUrls": ["https://bin.pega.io/artifactory/repo2-release/"],
      "groupName": "dependencies",
      "schedule": [
        "at any time"
      ]
    }
  ]
}